FACTORY_WEBHOOK_SECRET=change-me
FACTORY_MESHWIKI_URL=http://localhost:8000
FACTORY_MESHWIKI_API_KEY=change-me
FACTORY_ANTHROPIC_API_KEY=sk-ant-...    # Used by PM Agent (Opus 4) and grinder (Haiku fallback)
# FACTORY_MINIMAX_API_KEY=               # Used by e2b grinder for Kilo config
FACTORY_E2B_API_KEY=e2b-...
FACTORY_GITHUB_TOKEN=ghp_...            # fine-grained token: contents read/write + PRs write
FACTORY_GITHUB_REPO=jyrkihuhta/meshwiki
FACTORY_HOST=0.0.0.0
FACTORY_PORT=8001
FACTORY_REPO_ROOT=/path/to/meshwiki
FACTORY_GRINDER_PROVIDER=e2b            # e2b | anthropic | minimax
FACTORY_GRINDER_MODEL=MiniMax-M2.7
# FACTORY_MINIMAX_API_KEY is used by the e2b grinder for Kilo config
