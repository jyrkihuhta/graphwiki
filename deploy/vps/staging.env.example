# MeshWiki STAGING environment variables
# Copy this to /opt/meshwiki/staging.env on the VPS and fill in values.
# Staging runs from a live git checkout with --reload; changes take effect instantly on git pull.
# Never commit the real staging.env file.

# ── App ──────────────────────────────────────────────────────
MESHWIKI_DATA_DIR=/data/pages

# ── Auth ─────────────────────────────────────────────────────
MESHWIKI_AUTH_ENABLED=true
MESHWIKI_AUTH_PASSWORD=staging
# Random hex string: python3 -c "import secrets; print(secrets.token_hex(32))"
MESHWIKI_SESSION_SECRET=

# ── Agent Factory ────────────────────────────────────────────
# Keep factory disabled on staging by default to avoid grinders running
# against the staging wiki. Enable only when testing factory features.
MESHWIKI_FACTORY_ENABLED=false
MESHWIKI_FACTORY_API_KEY=
MESHWIKI_FACTORY_WEBHOOK_URL=http://orchestrator-staging:8001/webhook
MESHWIKI_FACTORY_WEBHOOK_SECRET=

# ── GitHub Integration ───────────────────────────────────────
# HMAC secret for verifying inbound GitHub webhooks (PR merged events).
# Must match the secret configured on the GitHub repo webhook.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
MESHWIKI_GITHUB_WEBHOOK_SECRET=
